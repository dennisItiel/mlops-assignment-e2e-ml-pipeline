# =============================================================================
# Inference
# =============================================================================
NEBIUS_API_KEY=XXX

# =============================================================================
# Project paths (required for DockerOperator bind mounts)
# On the VM, set this to the absolute repo path, e.g. /home/ubuntu/mlops-assignment-e2e-ml-pipeline
# =============================================================================
HOST_PROJECT_DIR=/home/ubuntu/mlops-assignment-e2e-ml-pipeline
CONTAINER_PROJECT_DIR=/opt/airflow/project
PIPELINE_IMAGE=mlops-assignment:latest

# =============================================================================
# MLflow
# =============================================================================
# Local standalone (easy mode):
# MLFLOW_TRACKING_URI=sqlite:////absolute/path/to/mlflow.db
# Production compose (services talk over docker network):
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-eval
MLFLOW_PORT=5000

# =============================================================================
# Airflow (production compose)
# =============================================================================
AIRFLOW_PORT=8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_UID=50000
DOCKER_GID=999
AIRFLOW_FERNET_KEY=
AIRFLOW_API_SECRET_KEY=change-me-in-production
AIRFLOW_API_AUTH_JWT_SECRET=change-me-in-production
PIPELINE_TASK_RETRIES=1

# =============================================================================
# Object storage (optional — leave S3_BUCKET empty to skip upload)
# Works with AWS S3, MinIO, Nebius Object Storage, etc.
# =============================================================================
S3_BUCKET=
S3_PREFIX=swe-bench-runs
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
